# Copy this file to .env.local (which is gitignored) and fill in real values.
# Consumed by publish.bat. KEY=VALUE, one per line; lines starting with # are ignored.

# PyPI API token — create at https://pypi.org/manage/account/token/
# Scope it to the "testhide-unittest-plugin" project once it exists.
PYPI_API_TOKEN=pypi-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
